# Firebase Configuration - Required for frontend
# Copy this file to .env.local and fill in your actual Firebase project credentials
# DO NOT commit .env.local to version control - it contains sensitive keys
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Server Configuration (deprecated - backend not in use)
# JWT_SECRET=altere-isso-em-producao-use-uma-string-longa-e-aleatoria
# NODE_ENV=development
